# Build Stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build-env
WORKDIR /app

# Copy csproj files and restore dependencies
COPY src/FlowSpace.Domain/*.csproj ./src/FlowSpace.Domain/
COPY src/FlowSpace.Application/*.csproj ./src/FlowSpace.Application/
COPY src/FlowSpace.Persistence/*.csproj ./src/FlowSpace.Persistence/
COPY src/FlowSpace.Infrastructure/*.csproj ./src/FlowSpace.Infrastructure/
COPY src/FlowSpace.Api/*.csproj ./src/FlowSpace.Api/
COPY src/FlowSpace.slnx ./src/

RUN dotnet restore ./src/FlowSpace.Api/FlowSpace.Api.csproj

# Copy everything else and build release
COPY . ./
RUN dotnet publish ./src/FlowSpace.Api/FlowSpace.Api.csproj -c Release -o out

# Runtime Stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build-env /app/out .

# Expose port 8080 (Render default port)
EXPOSE 8080
ENV ASPNETCORE_ENVIRONMENT=Production

# --- Memory-safety net for constrained hosts (Render free tier = 512MB) ---
# Force Workstation GC to minimize idle memory
ENV DOTNET_gcServer=0
ENV DOTNET_gcConcurrent=0
# Allow runtime to use more default heap space up to container limit without hard-cap crash
# Avoids a known W^X memory-protection crash on some constrained/low-memory Linux containers during JIT.
ENV DOTNET_EnableWriteXorExecute=0

# Render provides PORT at runtime. Fall back to 8080 so the image also runs locally.
ENTRYPOINT ["sh", "-c", "exec dotnet FlowSpace.Api.dll --urls http://0.0.0.0:${PORT:-8080}"]
