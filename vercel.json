{
  "version": 2,
  "public": true,
  "builds": [
    { "src": "fe/**/*.html", "use": "@vercel/static" },
    { "src": "fe/**/*.js",   "use": "@vercel/static" },
    { "src": "fe/**/*.css",  "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://api.flowspace.dev/api/$1",
      "methods": ["GET","POST","PUT","DELETE","PATCH"]
    },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
